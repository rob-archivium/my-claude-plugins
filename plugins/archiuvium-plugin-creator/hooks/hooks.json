{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate-plugin-structure.sh",
            "timeout": 15
          }
        ],
        "description": "Validate plugin structure when writing to a plugin directory"
      }
    ]
  }
}
